%h1= t('.title')

%p= t('.description')

%p
  = t('.examples')
  %ul
    %li= t('.example1')
    %li= t('.example2')

%table
  %thead
    %tr
      %th= t('.source_element')
      %th= t('.created_at')
      %th= t('.actions')
  %tbody
    - @registrant_group_types.each do |reg_group_type|
      %tr
        %td= link_to reg_group_type.source_element, [:convention_setup, reg_group_type]
        %td= l reg_group_type.created_at
        %td
          = link_to t('edit'), edit_convention_setup_registrant_group_type_path(reg_group_type)
          = link_to t('delete'), convention_setup_registrant_group_type_path(reg_group_type), method: :delete, data: { confirm: t('are_you_sure') }

= link_to t('.new_registrant_group_type'), new_convention_setup_registrant_group_type_path, class: "button"
