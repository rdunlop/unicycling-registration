%h1= t('.title', registrant_group_type: @registrant_group_type)
.non_printable
  = link_to "(" + t('.pdf') + ")", convention_setup_registrant_group_type_path(@registrant_group_type, format: :pdf)

%h2= t('.groups')

%table
  %thead
    %tr
      %th= t('.group_name')
      %th= t('.Members')
      %th= t('.Size')
  %tbody
    - @registrant_group_type.registrant_groups.each do |group|
      %tr
        %th
          .non_printable
            = link_to group.to_s, group
          .only_printable
            = group.to_s
        %th
        %th= group.registrant_group_members.size
      - group.registrant_group_members.each do |member|
        %tr
          %td= group.to_s
          %td= member
          %td
